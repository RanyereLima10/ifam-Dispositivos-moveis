        // Aplica o estilo do input
        style={styles.input}

        // Texto exibido dentro do campo
        placeholder="Digite o nome"

        // Atualiza o valor da variável nome
        onChangeText={setNome}
      />

      {/* Campo para digitar o email */}
      <TextInput

        // Aplica o estilo do input
        style={styles.input}

        // Texto exibido dentro do campo
        placeholder="Digite o email"

        // Atualiza o valor da variável email
        onChangeText={setEmail}
      />

      {/* Container do Switch */}
      <View style={styles.switchContainer}>

        {/* Texto ao lado do Switch */}
        <Text>
          Receber notificações
        </Text>

        {/* Componente Switch */}
        <Switch

          // Valor atual do Switch
          value={notificacao}

          // Atualiza o valor da variável notificacao
          onValueChange={setNotificacao}
        />

      </View>

      {/* Botão para cadastrar */}
      <Button

        // Texto exibido no botão
        title="Cadastrar"

        // Função executada ao clicar
        onPress={cadastrar}
      />

    </View>
