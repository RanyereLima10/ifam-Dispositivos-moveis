// Importa o React e o Hook useState
// useState é utilizado para armazenar valores que podem mudar
import React, { useState } from 'react';

// Importa os componentes necessários do React Native
import {
  View,        // Container para organizar elementos
  Text,        // Exibe textos na tela
  TextInput,   // Campo de entrada de texto
  Button,      // Botão padrão
  Switch,      // Botão de ligar/desligar
  StyleSheet,  // Criação de estilos
  Alert        // Exibe mensagens de alerta
} from 'react-native';

// Cria e exporta o componente principal App
export default function App() {

  // Cria a variável "nome"
  // setNome altera o valor digitado
  const [nome, setNome] = useState('');

  // Cria a variável "email"
  // setEmail altera o valor digitado
  const [email, setEmail] = useState('');

  // Cria a variável "notificacao"
  // false significa desligado inicialmente
  const [notificacao, setNotificacao] = useState(false);

  // Função executada ao clicar no botão
  function cadastrar() {

    // Exibe uma mensagem de alerta com os dados
    Alert.alert(

      // Título do alerta
      'Cadastro realizado',

      // Mensagem exibida
      'Nome: ' + nome +
      '\nEmail: ' + email +
      '\nNotificações: ' + notificacao
    );
  }

  // Retorna a interface gráfica
  return (

    // Container principal da aplicação
    <View style={styles.container}>

      {/* Título da tela */}
      <Text style={styles.titulo}>
