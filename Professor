        // Captura o texto digitado
        // e salva na variável nome
        onChangeText={setNome}
      />

      {/* Botão da aplicação */}
      <Button

        // Texto exibido no botão
        title="Enviar"

        // Função executada ao clicar
        onPress={enviarFormulario}
      />

    </View>
  );
}

