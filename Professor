// ============================================================================
// APP DE CADASTRO DE PRODUTOS - REACT NATIVE
// Desenvolvido para o IFAM - Campus Iranduba
// Autor: Ranyere Ney Osório Lima
// Descrição: Aplicação completa para cadastrar, listar, editar e deletar produtos
// ============================================================================

// IMPORTAÇÕES - Importamos os componentes necessários do React e React Native
import React, { useState } from 'react'; // useState para gerenciar estado da aplicação
import {
  View, // Componente container para organizar elementos
  Text, // Componente para exibir texto
  TextInput, // Componente para entrada de texto do usuário
  Button, // Componente para botões
  ScrollView, // Componente para fazer scroll em conteúdo grande
  Alert, // Componente para exibir alertas
  StyleSheet, // Para criar estilos CSS-like em React Native
  FlatList, // Componente otimizado para listas grandes
  TouchableOpacity, // Componente para detectar toque
} from 'react-native';

// ============================================================================
// COMPONENTE PRINCIPAL - App
// Este é o componente raiz que gerencia toda a aplicação
// ============================================================================
export default function App() {
  // ========================================================================
  // ESTADOS DA APLICAÇÃO - Usando o hook useState para gerenciar dados
  // ========================================================================

  // Estado para armazenar a lista de produtos cadastrados
  // Inicializa com um array vazio
  const [produtos, setProdutos] = useState([]);

  // Estado para controlar qual tela está sendo exibida
  // Pode ser: 'lista', 'cadastro' ou 'edicao'
  const [telaAtual, setTelaAtual] = useState('lista');

  // Estado para armazenar o produto sendo editado
  // Inicializa como null (nenhum produto em edição)
  const [produtoEmEdicao, setProdutoEmEdicao] = useState(null);

  // ========================================================================
  // CAMPOS DO FORMULÁRIO - Estados para cada campo de entrada
  // ========================================================================

  // Estado para armazenar o nome do produto digitado no formulário
  const [nome, setNome] = useState('');

  // Estado para armazenar o preço do produto digitado no formulário
  const [preco, setPreco] = useState('');

  // Estado para armazenar a categoria selecionada do produto
  const [categoria, setCategoria] = useState('Eletrônicos');

  // Estado para armazenar a descrição do produto digitada no formulário
  const [descricao, setDescricao] = useState('');

  // ========================================================================
  // FUNÇÃO: Validar Formulário
  // Verifica se todos os campos estão preenchidos corretamente
  // Retorna true se válido, false se houver erro
  // ========================================================================
  const validarFormulario = () => {
    // Verifica se o nome está vazio ou tem menos de 3 caracteres
    if (!nome || nome.trim().length < 3) {
      // Exibe alerta de erro ao usuário
      Alert.alert(
        'Erro de Validação', // Título do alerta
        'Nome deve ter no mínimo 3 caracteres' // Mensagem do alerta
      );
      return false; // Retorna false indicando validação falhou
    }

    // Verifica se o preço está vazio, não é número ou é menor/igual a 0
    if (!preco || isNaN(preco) || parseFloat(preco) <= 0) {
      // Exibe alerta de erro ao usuário
      Alert.alert(
        'Erro de Validação',
        'Preço deve ser um número válido e maior que 0'
      );
      return false; // Retorna false indicando validação falhou
    }

    // Verifica se a categoria está vazia
    if (!categoria) {
      // Exibe alerta de erro ao usuário
      Alert.alert(
        'Erro de Validação',
        'Selecione uma categoria'
      );
      return false; // Retorna false indicando validação falhou
    }

    // Se passou em todas as validações, retorna true
    return true;
  };

  // ========================================================================
  // FUNÇÃO: Cadastrar Produto
  // Adiciona um novo produto à lista após validação
  // ========================================================================
  const handleCadastrar = () => {
    // Chama a função de validação
    if (validarFormulario()) {
      // Cria um novo objeto de produto com os dados do formulário
      const novoProduto = {
        id: Date.now(), // Usa timestamp como ID único do produto
        nome: nome.trim(), // Remove espaços em branco do nome
        preco: parseFloat(preco), // Converte preço para número decimal
        categoria: categoria, // Armazena a categoria selecionada
        descricao: descricao.trim(), // Remove espaços em branco da descrição
      };

      // Adiciona o novo produto ao array de produtos
      // Usa spread operator para criar novo array (imutabilidade)
      setProdutos([...produtos, novoProduto]);

      // Limpa todos os campos do formulário
      limparCampos();

      // Exibe mensagem de sucesso ao usuário
      Alert.alert(
        'Sucesso',
        'Produto cadastrado com sucesso!'
      );

      // Volta para a tela de listagem
      setTelaAtual('lista');
    }
  };

  // ========================================================================
  // FUNÇÃO: Atualizar Produto
  // Atualiza os dados de um produto existente
  // ========================================================================
  const handleAtualizar = () => {
    // Chama a função de validação
    if (validarFormulario()) {
      // Cria um novo array de produtos
      const produtosAtualizados = produtos.map((produto) => {
        // Se o ID do produto corresponder ao produto em edição
        if (produto.id === produtoEmEdicao.id) {
          // Retorna o produto com dados atualizados
          return {
            id: produto.id, // Mantém o ID original
            nome: nome.trim(), // Atualiza o nome
            preco: parseFloat(preco), // Atualiza o preço
            categoria: categoria, // Atualiza a categoria
            descricao: descricao.trim(), // Atualiza a descrição
          };
        }
        // Se não for o produto em edição, retorna sem mudanças
        return produto;
      });

      // Atualiza o estado com a lista de produtos modificada
      setProdutos(produtosAtualizados);

      // Limpa os campos do formulário
      limparCampos();

      // Limpa o estado de produto em edição
      setProdutoEmEdicao(null);

      // Exibe mensagem de sucesso ao usuário
      Alert.alert(
        'Sucesso',
        'Produto atualizado com sucesso!'
      );

      // Volta para a tela de listagem
      setTelaAtual('lista');
    }
  };

  // ========================================================================
  // FUNÇÃO: Deletar Produto
  // Remove um produto da lista após confirmação do usuário
  // ========================================================================
  const handleDeletar = (id) => {
    // Exibe um alerta de confirmação antes de deletar
    Alert.alert(
      'Confirmar Exclusão', // Título do alerta
      'Tem certeza que deseja deletar este produto?', // Mensagem
      [
        // Array de botões do alerta
        {
          text: 'Cancelar', // Texto do botão
          onPress: () => {}, // Função executada ao clicar (não faz nada)
          style: 'cancel', // Estilo do botão (cancelamento)
        },
        {
          text: 'Deletar', // Texto do botão
          onPress: () => {
            // Filtra o array removendo o produto com o ID correspondente
            const produtosFiltrados = produtos.filter(
              (produto) => produto.id !== id // Mantém apenas produtos com ID diferente
            );

            // Atualiza o estado com a lista filtrada
            setProdutos(produtosFiltrados);

            // Exibe mensagem de sucesso
            Alert.alert(
              'Sucesso',
              'Produto deletado com sucesso!'
            );
          },
          style: 'destructive', // Estilo do botão (destruição/exclusão)
        },
      ]
    );
  };

  // ========================================================================
  // FUNÇÃO: Iniciar Edição
  // Prepara o formulário para editar um produto existente
  // ========================================================================
  const handleEditarInicio = (produto) => {
    // Armazena o produto que será editado
    setProdutoEmEdicao(produto);

    // Preenche os campos do formulário com os dados do produto
    setNome(produto.nome); // Preenche o nome
    setPreco(produto.preco.toString()); // Converte preço para string e preenche
    setCategoria(produto.categoria); // Preenche a categoria
    setDescricao(produto.descricao); // Preenche a descrição

    // Muda para a tela de edição
    setTelaAtual('edicao');
  };

  // ========================================================================
  // FUNÇÃO: Limpar Campos
  // Reseta todos os campos do formulário para valores vazios
  // ========================================================================
  const limparCampos = () => {
    // Reseta o nome para string vazia
    setNome('');

    // Reseta o preço para string vazia
    setPreco('');

    // Reseta a categoria para valor padrão
    setCategoria('Eletrônicos');

    // Reseta a descrição para string vazia
    setDescricao('');
  };

  // ========================================================================
  // FUNÇÃO: Cancelar Edição
  // Cancela a edição e volta para a tela de listagem
  // ========================================================================
  const handleCancelarEdicao = () => {
    // Limpa os campos do formulário
    limparCampos();

    // Limpa o estado de produto em edição
    setProdutoEmEdicao(null);

    // Volta para a tela de listagem
    setTelaAtual('lista');
  };

  // ========================================================================
  // RENDERIZAÇÃO CONDICIONAL - Exibe diferentes telas conforme o estado
  // ========================================================================

  // Se a tela atual for 'lista', renderiza a tela de listagem
  if (telaAtual === 'lista') {
    return (
      <View style={styles.container}>
        {/* HEADER - Cabeçalho da aplicação */}
        <View style={styles.header}>
          {/* Título da aplicação */}
          <Text style={styles.headerTitle}>Cadastro de Produtos</Text>

          {/* Botão para ir para tela de cadastro */}
          <Button
            title="Novo Produto" // Texto do botão
            onPress={() => {
              // Limpa os campos antes de ir para cadastro
              limparCampos();
              // Muda para a tela de cadastro
              setTelaAtual('cadastro');
            }}
            color="#059669" // Cor verde do botão
          />
        </View>

        {/* LISTA DE PRODUTOS */}
        <ScrollView style={styles.listaContainer}>
          {/* Verifica se há produtos cadastrados */}
          {produtos.length === 0 ? (
            // Se não há produtos, exibe mensagem vazia
            <View style={styles.emptyState}>
              <Text style={styles.emptyStateText}>
                Nenhum produto cadastrado. Clique em "Novo Produto" para começar!
              </Text>
            </View>
          ) : (
            // Se há produtos, renderiza cada um
            produtos.map((produto) => (
              // Container de cada produto (cartão)
              <View key={produto.id} style={styles.produtoCard}>
                {/* Nome do produto */}
                <Text style={styles.produtoNome}>{produto.nome}</Text>

                {/* Preço do produto formatado em moeda */}
                <Text style={styles.produtoPreco}>
                  R$ {produto.preco.toFixed(2)}
                </Text>

                {/* Categoria do produto */}
                <Text style={styles.produtoCategoria}>
                  Categoria: {produto.categoria}
                </Text>

                {/* Descrição do produto */}
                <Text style={styles.produtoDescricao}>
                  {produto.descricao}
                </Text>

                {/* Container dos botões de ação */}
                <View style={styles.botoesContainer}>
                  {/* Botão para editar o produto */}
                  <TouchableOpacity
                    style={[styles.botao, styles.botaoEditar]}
                    onPress={() => handleEditarInicio(produto)}
                  >
                    <Text style={styles.textoBotao}>Editar</Text>
                  </TouchableOpacity>

                  {/* Botão para deletar o produto */}
                  <TouchableOpacity
                    style={[styles.botao, styles.botaoDeletar]}
                    onPress={() => handleDeletar(produto.id)}
                  >
                    <Text style={styles.textoBotao}>Deletar</Text>
                  </TouchableOpacity>
                </View>
              </View>
            ))
          )}
        </ScrollView>
      </View>
    );
  }

  // Se a tela atual for 'cadastro', renderiza a tela de cadastro
  if (telaAtual === 'cadastro') {
    return (
      <View style={styles.container}>
        {/* HEADER - Cabeçalho da tela de cadastro */}
        <View style={styles.header}>
          <Text style={styles.headerTitle}>Novo Produto</Text>
        </View>

        {/* FORMULÁRIO */}
        <ScrollView style={styles.formularioContainer}>
          {/* CAMPO: Nome do Produto */}
          <Text style={styles.label}>Nome do Produto *</Text>
          <TextInput
            style={styles.input} // Estilo do campo de entrada
            placeholder="Digite o nome do produto" // Texto de placeholder
            value={nome} // Valor atual do campo
            onChangeText={setNome} // Função chamada quando o texto muda
            placeholderTextColor="#999" // Cor do placeholder
          />

          {/* CAMPO: Preço */}
          <Text style={styles.label}>Preço *</Text>
          <TextInput
            style={styles.input} // Estilo do campo de entrada
            placeholder="Digite o preço (ex: 99.90)" // Texto de placeholder
            value={preco} // Valor atual do campo
            onChangeText={setPreco} // Função chamada quando o texto muda
            keyboardType="decimal-pad" // Teclado numérico com ponto decimal
            placeholderTextColor="#999" // Cor do placeholder
          />

          {/* CAMPO: Categoria */}
          <Text style={styles.label}>Categoria *</Text>
          <View style={styles.categoriaContainer}>
            {/* Array de categorias disponíveis */}
            {['Eletrônicos', 'Roupas', 'Alimentos', 'Outros'].map(
              (cat) => (
                // Botão para cada categoria
                <TouchableOpacity
                  key={cat} // Chave única para cada elemento
                  style={[
                    styles.categoriaBotao, // Estilo base
                    categoria === cat && styles.categoriaSelecionada, // Estilo se selecionada
                  ]}
                  onPress={() => setCategoria(cat)} // Define categoria ao clicar
                >
                  <Text
                    style={[
                      styles.categoriaBotaoTexto,
                      categoria === cat && styles.categoriaSelecionadaTexto,
                    ]}
                  >
                    {cat}
                  </Text>
                </TouchableOpacity>
              )
            )}
          </View>

          {/* CAMPO: Descrição */}
          <Text style={styles.label}>Descrição</Text>
          <TextInput
            style={[styles.input, styles.descricaoInput]} // Estilo com altura maior
            placeholder="Digite a descrição do produto" // Texto de placeholder
            value={descricao} // Valor atual do campo
            onChangeText={setDescricao} // Função chamada quando o texto muda
            multiline // Permite múltiplas linhas
            numberOfLines={4} // Número inicial de linhas
            placeholderTextColor="#999" // Cor do placeholder
          />

          {/* BOTÕES DE AÇÃO */}
          <View style={styles.botaoContainer}>
            {/* Botão Cadastrar */}
            <Button
              title="Cadastrar" // Texto do botão
              onPress={handleCadastrar} // Função chamada ao clicar
              color="#1E40AF" // Cor azul do botão
            />

            {/* Botão Limpar */}
            <Button
              title="Limpar" // Texto do botão
              onPress={limparCampos} // Função chamada ao clicar
              color="#FF6B6B" // Cor vermelha do botão
            />

            {/* Botão Voltar */}
            <Button
              title="Voltar" // Texto do botão
              onPress={() => {
                // Limpa campos antes de voltar
                limparCampos();
                // Volta para a tela de listagem
                setTelaAtual('lista');
              }}
              color="#999" // Cor cinza do botão
            />
          </View>
        </ScrollView>
      </View>
    );
  }

  // Se a tela atual for 'edicao', renderiza a tela de edição
  if (telaAtual === 'edicao') {
    return (
      <View style={styles.container}>
        {/* HEADER - Cabeçalho da tela de edição */}
        <View style={styles.header}>
          <Text style={styles.headerTitle}>Editar Produto</Text>
        </View>

        {/* FORMULÁRIO - Mesmo formulário do cadastro, mas para edição */}
        <ScrollView style={styles.formularioContainer}>
          {/* CAMPO: Nome do Produto */}
          <Text style={styles.label}>Nome do Produto *</Text>
          <TextInput
            style={styles.input}
            placeholder="Digite o nome do produto"
            value={nome}
            onChangeText={setNome}
            placeholderTextColor="#999"
          />

          {/* CAMPO: Preço */}
          <Text style={styles.label}>Preço *</Text>
          <TextInput
            style={styles.input}
            placeholder="Digite o preço (ex: 99.90)"
            value={preco}
            onChangeText={setPreco}
            keyboardType="decimal-pad"
            placeholderTextColor="#999"
          />

          {/* CAMPO: Categoria */}
          <Text style={styles.label}>Categoria *</Text>
          <View style={styles.categoriaContainer}>
            {['Eletrônicos', 'Roupas', 'Alimentos', 'Outros'].map(
              (cat) => (
                <TouchableOpacity
                  key={cat}
                  style={[
                    styles.categoriaBotao,
                    categoria === cat && styles.categoriaSelecionada,
                  ]}
                  onPress={() => setCategoria(cat)}
                >
                  <Text
                    style={[
                      styles.categoriaBotaoTexto,
                      categoria === cat && styles.categoriaSelecionadaTexto,
                    ]}
                  >
                    {cat}
                  </Text>
                </TouchableOpacity>
              )
            )}
          </View>

          {/* CAMPO: Descrição */}
          <Text style={styles.label}>Descrição</Text>
          <TextInput
            style={[styles.input, styles.descricaoInput]}
            placeholder="Digite a descrição do produto"
            value={descricao}
            onChangeText={setDescricao}
            multiline
            numberOfLines={4}
            placeholderTextColor="#999"
          />

          {/* BOTÕES DE AÇÃO */}
          <View style={styles.botaoContainer}>
            {/* Botão Atualizar */}
            <Button
              title="Atualizar" // Texto do botão
              onPress={handleAtualizar} // Função chamada ao clicar
              color="#1E40AF" // Cor azul do botão
            />

            {/* Botão Cancelar */}
            <Button
              title="Cancelar" // Texto do botão
              onPress={handleCancelarEdicao} // Função chamada ao clicar
              color="#999" // Cor cinza do botão
            />
          </View>
        </ScrollView>
      </View>
    );
  }
}

