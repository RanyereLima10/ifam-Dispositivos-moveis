// Importa o React e o Hook useState
// useState é usado para armazenar valores que podem mudar
import React, { useState } from 'react';

// Importa os componentes View, Text e Switch do React Native
import {
  View,    // Container para organizar elementos
  Text,    // Exibe textos na tela
  Switch   // Componente de botão liga/desliga
} from 'react-native';

// Cria e exporta o componente principal App
export default function App() {

  // Cria a variável "ativo"
  // setAtivo altera o valor da variável
  // false significa que o switch inicia desligado
  const [ativo, setAtivo] = useState(false);

  // Retorno da interface gráfica
  return (

    // View principal da aplicação
    <View style={{ marginTop: 50, padding: 20 }}>

      {/* Texto exibido acima do Switch */}
      <Text style={{ fontSize: 20, marginBottom: 10 }}>
        Receber notificações
      </Text>

      {/* Componente Switch */}
      <Switch

        // Define o valor atual do Switch
        // true = ligado
        // false = desligado
        value={ativo}

        // Função chamada quando o usuário altera o Switch
        // Atualiza o valor da variável "ativo"
        onValueChange={setAtivo}
      />

      {/* Mostra o estado atual do Switch */}
      <Text style={{ marginTop: 10, fontSize: 18 }}>

        {/* Operador ternário */}
        {/* Se ativo for true mostra "Ativado" */}
        {/* Senão mostra "Desativado" */}
        Status: {ativo ? 'Ativado' : 'Desativado'}

      </Text>

    </View>
  );
}


