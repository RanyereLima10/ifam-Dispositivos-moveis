Este código implementa um formulário de cadastro em React Native utilizando o ambiente Expo Snack, no qual são coletadas informações do usuário como nome, e-mail, CPF e data de nascimento. 
Para isso, são utilizados componentes como TextInput para entrada de dados, Text para rótulos, View para organização do layout e TouchableOpacity para criar o botão de envio. 
O gerenciamento dos dados digitados é feito por meio do hook useState, que armazena os valores de cada campo em variáveis de estado. 
A data de nascimento é inserida em três campos separados (dia, mês e ano), permitindo maior controle da entrada. 
Ao pressionar o botão “Inscreva-se”, a função handleSubmit é executada, reunindo todas as informações e exibindo-as em um alerta na tela utilizando o Alert, simulando o envio dos dados. 
O estilo visual é definido com StyleSheet, garantindo uma interface simples, organizada e semelhante a um formulário real.
************+***************************************************************
import React, { useState } from 'react';
import { View, Text, TextInput, StyleSheet, TouchableOpacity, Alert } from 'react-native';

export default function App() {
  const [nome, setNome] = useState('');
  const [email, setEmail] = useState('');
  const [cpf, setCpf] = useState('');
  const [dia, setDia] = useState('');
  const [mes, setMes] = useState('');
  const [ano, setAno] = useState('');

  const handleSubmit = () => {
    const data = `${dia}/${mes}/${ano}`;

    Alert.alert(
      "Dados",
      `Nome: ${nome}\nEmail: ${email}\nCPF: ${cpf}\nNascimento: ${data}`
    );
  };

  return (
    <View style={styles.container}>
      <Text style={styles.title}>Inscreva-se</Text>

      <Text style={styles.label}>Nome</Text>
      <TextInput
        style={styles.input}
        value={nome}
        onChangeText={setNome}
      />

      <Text style={styles.label}>E-mail</Text>
      <TextInput
        style={styles.input}
        value={email}
        onChangeText={setEmail}
        keyboardType="email-address"
      />

      <Text style={styles.label}>CPF</Text>
      <TextInput
        style={styles.input}
        value={cpf}
        onChangeText={setCpf}
        keyboardType="numeric"
      />

      <Text style={styles.label}>Data de Nascimento</Text>

      <View style={styles.row}>
        <TextInput
          style={styles.dateInput}
          placeholder="Dia"
          keyboardType="numeric"
          maxLength={2}
          value={dia}
          onChangeText={setDia}
        />

        <TextInput
          style={styles.dateInput}
          placeholder="Mês"
          keyboardType="numeric"
          maxLength={2}
          value={mes}
          onChangeText={setMes}
        />

        <TextInput
          style={styles.dateInput}
          placeholder="Ano"
          keyboardType="numeric"
          maxLength={4}
          value={ano}
          onChangeText={setAno}
        />
      </View>

      <TouchableOpacity style={styles.button} onPress={handleSubmit}>
        <Text style={styles.buttonText}>Inscreva-se</Text>
      </TouchableOpacity>
    </View>
  );
}

const styles = StyleSheet.create({
  container: {
    flex: 1,
    padding: 20,
    backgroundColor: '#f5f5f5',
    justifyContent: 'center'
  },
  title: {
    fontSize: 22,
